# AgentKit SaaS — Variables de entorno del backend
# Copia como .env y completa los valores

# ── Base de datos ─────────────────────────────────────────
# Local (dev con Docker Compose):
DATABASE_URL=postgresql+asyncpg://agentkit:agentkit@localhost:5432/agentkit
# Produccion (Railway):
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname

# ── JWT Secret ────────────────────────────────────────────
# Genera uno seguro para produccion: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=dev-secret-change-in-production

# ── Servidor ──────────────────────────────────────────────
PORT=8000
ENVIRONMENT=development

# ── CORS (URL del frontend) ──────────────────────────────
CORS_ORIGINS=http://localhost:3000
